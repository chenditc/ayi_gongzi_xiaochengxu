<view class="page">
  <view class="monthbar">
    <button class="btn mini secondary" size="mini" bindtap="onPrevMonth">上月</button>
    <view class="monthtitle">
      <text class="monthtitle-text">{{year}}年{{monthIndexPlus1}}月</text>
    </view>
    <button class="btn mini secondary" size="mini" bindtap="onNextMonth">下月</button>
  </view>

  <view class="actions">
    <button class="btn mini secondary" size="mini" bindtap="onSelectAllMonth">全选本月</button>
    <button class="btn mini secondary" size="mini" bindtap="onDeselectAllMonth">取消本月</button>
    <button
      class="btn mini {{pairingMode ? 'pairing-active' : 'secondary'}}"
      size="mini"
      bindtap="onTogglePairingMode"
      id="pairBtn"
    >{{pairingMode ? '取消调休' : '协商调休'}}</button>
    <button class="btn mini danger" size="mini" bindtap="onClearStorage">重新选择</button>
  </view>

  <view wx:if="{{pairingMode}}" class="pairing-banner">
    <view wx:if="{{!pairingFirstDate}}" class="pairing-hint">
      <text class="pairing-step">第 1 步</text>
      <text class="pairing-text">点选一个法定节假日（带「法」角标）</text>
    </view>
    <view wx:else class="pairing-hint">
      <text class="pairing-step">第 2 步</text>
      <text class="pairing-text">已选 {{pairingFirstDate}}，再点一个本月非节假日完成调休</text>
    </view>
  </view>

  <view class="calendar" id="calendarArea">
    <view class="week-header" id="weekHeader">
      <view
        class="week-cell"
        wx:for="{{weekdays}}"
        wx:key="*this"
        bindtap="onToggleWeekdayColumn"
        data-weekday="{{index}}"
      >
        <text class="week-text">周{{item}}</text>
        <text class="week-check" wx:if="{{weekdayColumnAllSelected[index]}}">✓</text>
      </view>
    </view>

    <view class="grid">
      <view
        wx:for="{{calendarCells}}"
        wx:key="index"
        class="cell {{item.empty ? 'empty' : ''}} {{item.selected ? 'selected' : ''}} {{item.isHoliday ? 'holiday' : ''}} {{item.isHolidayWorked ? 'holiday-worked' : ''}} {{item.isSwapHoliday ? 'swap-holiday' : ''}} {{item.isSwapSwap ? 'swap-target' : ''}} {{item.pairingFirstSelected ? 'pairing-first' : ''}}"
        bindtap="onToggleDay"
        data-datestr="{{item.dateStr}}"
      >
        <text wx:if="{{item.isSwapHoliday}}" class="badge-swap">调</text>
        <text wx:elif="{{item.isSwapSwap}}" class="badge-swap badge-swap-rest">休</text>
        <text wx:elif="{{item.isHoliday}}" class="badge-holiday">法</text>
        <text class="cell-text">{{item.empty ? '' : item.day}}</text>
        <text wx:if="{{item.isHoliday && item.holidayName && !item.isSwapHoliday}}" class="holiday-name">{{item.holidayName}}</text>
        <text wx:if="{{item.swapPartnerDay}}" class="swap-partner">↔{{item.swapPartnerDay}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="row">
      <text class="label">月薪</text>
      <input
        class="input"
        type="number"
        value="{{monthlySalary}}"
        placeholder="例如 8000"
        bindinput="onSalaryInput"
      />
    </view>
    <view class="row">
      <text class="label">应出勤(天)</text>
      <input
        class="input"
        type="number"
        value="{{workDays}}"
        placeholder="0-31"
        bindinput="onWorkDaysInput"
        bindblur="onWorkDaysBlur"
      />
    </view>
  </view>

  <view class="card result-card">
    <view class="result-top">
      <text class="result-title">计算结果</text>
      <view class="result-right">
        <text class="result-amount">￥{{salaryResultText}}</text>
        <button class="btn mini primary" id="shareBtn" size="mini" open-type="share">分享工资单</button>
      </view>
    </view>
    <text class="muted result-breakdown">
      工作日上工 {{workedCount}} 天 + 法定节假日(带薪) {{holidayPaidCount}} 天 + 节假日加班 {{holidayWorkedCount}} 天(额外×2) = 计薪单位 {{payUnits}} 天
    </text>
    <text wx:if="{{swapPairsCount > 0}}" class="muted result-swap-note">
      已扣除 {{swapPairsCount}} 对协商调休（节假日按工作日计、对应工作日按带薪休息计）
    </text>
    <text class="muted result-formula">{{resultText}}</text>
  </view>

  <view wx:if="{{swapPairsCount > 0}}" class="card swap-card">
    <view class="swap-card-top">
      <text class="swap-card-title">协商调休（{{swapPairsCount}} 对）</text>
      <button class="btn mini secondary" size="mini" bindtap="onToggleSwapList">
        {{showSwapList ? '收起' : '展开'}}
      </button>
    </view>
    <view wx:if="{{showSwapList}}" class="swap-list">
      <view class="swap-item" wx:for="{{swapPairsDisplay}}" wx:key="holiday">
        <text class="swap-item-text">{{item.displayText}}</text>
        <button
          class="btn mini secondary swap-remove-btn"
          size="mini"
          bindtap="onRemoveSwapPair"
          data-holiday="{{item.holiday}}"
        >解除</button>
      </view>
    </view>
  </view>

  <view class="selectedbar">
    <view class="selectedbar-actions">
      <button class="btn mini" size="mini" bindtap="onToggleSelectedList">
        {{showSelectedList ? '隐藏明细' : '显示明细'}}
      </button>
    </view>
  </view>

  <view wx:if="{{showSelectedList}}" class="card">
    <scroll-view class="selected-list" scroll-y="true">
      <view
        class="selected-item"
        wx:for="{{selectedDatesDisplay}}"
        wx:key="dateStr"
      >
        <text>{{item.displayText}}</text>
      </view>
      <view wx:if="{{selectedDatesDisplay.length == 0}}" class="selected-empty muted">
        <text>暂无选择</text>
      </view>
    </scroll-view>
  </view>

  <view class="status muted">
    <text>{{storageStatus}}</text>
  </view>

  <view
    wx:if="{{guideVisible}}"
    class="guide"
    catchtap="onGuideCatch"
    catchtouchmove="onGuideCatch"
  >
    <view class="guide-mask" style="{{guideMask.top}}" catchtap="onGuideCatch"></view>
    <view class="guide-mask" style="{{guideMask.left}}" catchtap="onGuideCatch"></view>
    <view class="guide-mask" style="{{guideMask.right}}" catchtap="onGuideCatch"></view>
    <view class="guide-mask" style="{{guideMask.bottom}}" catchtap="onGuideCatch"></view>

    <view
      class="guide-spot"
      style="left:{{guideRect.left}}px;top:{{guideRect.top}}px;width:{{guideRect.width}}px;height:{{guideRect.height}}px;"
      catchtap="onGuideCatch"
    ></view>

    <view class="guide-tip" style="{{guideTipStyle}}" catchtap="onGuideCatch">
      <view class="guide-tip-text">{{guideText}}</view>
      <view class="guide-tip-actions">
        <button class="btn mini primary guide-tip-btn" size="mini" bindtap="onGuideNext">
          {{guideButtonText}}
        </button>
      </view>
    </view>
  </view>
</view>
