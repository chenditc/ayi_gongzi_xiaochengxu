.page {
  padding: 24rpx;
}

.monthbar {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 16rpx 0;
  background: #f6f7fb;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.monthtitle {
  flex: 1;
  text-align: center;
}

.monthtitle-text {
  font-size: 34rpx;
  font-weight: 600;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 8rpx 0 18rpx;
}

.btn.mini {
  padding: 0 18rpx;
  border-radius: 12rpx;
}

.btn.secondary {
  color: #333;
  background: #fff;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn.secondary::after {
  border: none;
}

.btn.secondary:active {
  opacity: 0.92;
  transform: translateY(1rpx);
}

.btn.primary {
  color: #fff;
  background: #07c160;
}

.btn.primary::after {
  border: none;
}

.btn.primary:active {
  opacity: 0.9;
}

.btn.danger {
  color: #fff;
  background: #e64646;
}

.btn.danger::after {
  border: none;
}

.btn.danger:active {
  opacity: 0.9;
}

.calendar {
  background: #fff;
  border-radius: 18rpx;
  padding: 14rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
}

.week-header {
  display: flex;
  margin-bottom: 8rpx;
}

.week-cell {
  width: 14.2857%;
  text-align: center;
  padding: 10rpx 0;
  border-radius: 12rpx;
  background: #f3f5fa;
  position: relative;
}

.week-text {
  font-size: 24rpx;
  color: #444;
}

.week-check {
  position: absolute;
  right: 10rpx;
  top: 6rpx;
  font-size: 22rpx;
  color: #07c160;
  font-weight: 700;
}

.grid {
  display: flex;
  flex-wrap: wrap;
}

.cell {
  width: 14.2857%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  margin: 4rpx 0;
  position: relative;
}

.cell.empty {
  background: #eef0f5;
}

.cell.holiday {
  background: #fff7f0;
}

.cell.holiday .cell-text {
  color: #d9480f;
  font-weight: 700;
}

.cell.selected {
  background: #07c160;
}

.cell-text {
  font-size: 30rpx;
  color: #222;
}

.cell.selected .cell-text {
  color: #fff;
  font-weight: 600;
}

.cell.selected.holiday .cell-text {
  color: #fff;
}

.badge-holiday {
  position: absolute;
  right: 10rpx;
  top: 8rpx;
  font-size: 20rpx;
  line-height: 22rpx;
  padding: 2rpx 6rpx;
  border-radius: 8rpx;
  background: #e8590c;
  color: #fff;
  font-weight: 800;
}

.holiday-name {
  position: absolute;
  left: 8rpx;
  bottom: 6rpx;
  font-size: 18rpx;
  color: #e8590c;
  max-width: 110rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell.selected .holiday-name {
  color: rgba(255, 255, 255, 0.95);
}

.cell.holiday-worked {
  box-shadow: 0 0 0 4rpx rgba(134, 46, 156, 0.6) inset;
}

.cell.selected.holiday-worked {
  background: #862e9c;
}

.cell.selected.holiday-worked .cell-text {
  color: #fff;
  font-weight: 700;
}

.cell.selected.holiday-worked .badge-holiday {
  background: rgba(255, 255, 255, 0.92);
  color: #862e9c;
}

/* --- Swap pairing styles --- */

.cell.swap-holiday {
  background: #fff;
  box-shadow: 0 0 0 3rpx rgba(134, 46, 156, 0.55) inset;
}

.cell.swap-holiday .cell-text {
  color: #222;
  font-weight: 600;
}

.cell.selected.swap-holiday {
  background: #07c160;
}

.cell.selected.swap-holiday .cell-text {
  color: #fff;
}

.cell.swap-target {
  background: #f5e9fa;
  box-shadow: 0 0 0 3rpx rgba(134, 46, 156, 0.55) inset;
}

.cell.swap-target .cell-text {
  color: #862e9c;
  font-weight: 600;
}

.badge-swap {
  position: absolute;
  right: 8rpx;
  top: 6rpx;
  font-size: 20rpx;
  line-height: 22rpx;
  padding: 2rpx 6rpx;
  border-radius: 8rpx;
  background: #862e9c;
  color: #fff;
  font-weight: 800;
}

.badge-swap-rest {
  background: #862e9c;
}

.cell.selected.swap-holiday .badge-swap {
  background: rgba(255, 255, 255, 0.92);
  color: #862e9c;
}

.swap-partner {
  position: absolute;
  left: 8rpx;
  bottom: 6rpx;
  font-size: 18rpx;
  color: #862e9c;
  font-weight: 600;
}

.cell.selected.swap-holiday .swap-partner {
  color: rgba(255, 255, 255, 0.95);
}

.cell.pairing-first {
  box-shadow: 0 0 0 4rpx #07c160 inset;
}

/* Pairing mode banner */

.pairing-banner {
  margin: 0 0 14rpx;
  padding: 16rpx 20rpx;
  background: #f5e9fa;
  border: 1rpx solid rgba(134, 46, 156, 0.3);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pairing-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.pairing-step {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #862e9c;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

.pairing-text {
  font-size: 26rpx;
  color: #5b2375;
}

.btn.pairing-active {
  color: #fff;
  background: #862e9c;
  border: none;
}

.btn.pairing-active::after {
  border: none;
}

.btn.pairing-active:active {
  opacity: 0.92;
}

/* Swap pair management card */

.swap-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4rpx;
}

.swap-card-title {
  font-weight: 700;
  font-size: 28rpx;
  color: #5b2375;
}

.swap-list {
  margin-top: 8rpx;
}

.swap-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0e4f7;
}

.swap-item:last-child {
  border-bottom: none;
}

.swap-item-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.swap-remove-btn {
  flex-shrink: 0;
  color: #862e9c;
  border: 1rpx solid rgba(134, 46, 156, 0.3);
}

.result-swap-note {
  display: block;
  font-size: 22rpx;
  color: #862e9c;
  margin-top: 4rpx;
  margin-bottom: 4rpx;
}

.card {
  margin-top: 18rpx;
  background: #fff;
  border-radius: 18rpx;
  padding: 18rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.label {
  width: 190rpx;
  color: #333;
  font-weight: 600;
}

.input {
  flex: 1;
  text-align: right;
  padding: 8rpx 10rpx;
  background: #f7f8fb;
  border-radius: 12rpx;
}

.result-card {
  padding-top: 16rpx;
}

.result-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.result-right {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.result-title {
  font-weight: 700;
  font-size: 30rpx;
}

.result-amount {
  font-weight: 800;
  font-size: 40rpx;
  color: #111;
}

.result-formula {
  font-size: 24rpx;
}

.result-breakdown {
  display: block;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.selectedbar {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.selectedbar-actions {
  display: flex;
  justify-content: flex-end;
}

.selected-list {
  max-height: 320rpx;
}

.selected-item {
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.selected-empty {
  padding: 16rpx 0;
  text-align: center;
}

.status {
  margin-top: 18rpx;
  text-align: center;
  font-size: 24rpx;
}

.guide {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  z-index: 9999;
}

.guide-mask {
  position: fixed;
  background: rgba(0, 0, 0, 0.55);
  z-index: 1;
}

.guide-spot {
  position: fixed;
  border: 3px solid #07c160;
  border-radius: 16rpx;
  box-shadow: 0 0 0 6rpx rgba(7, 193, 96, 0.25);
  z-index: 2;
}

.guide-tip {
  position: fixed;
  width: 560rpx;
  max-width: calc(100vw - 48rpx);
  background: #fff;
  border-radius: 18rpx;
  padding: 18rpx;
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.18);
  z-index: 3;
}

.guide-tip-text {
  font-size: 28rpx;
  color: #111;
  line-height: 1.5;
}

.guide-tip-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.guide-tip-btn {
  min-width: 160rpx;
}

